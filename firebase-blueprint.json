{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Public profile details of a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "characterProgress": { "type": "object", "description": "Persistent XP, levels, and stat boosts for character classes" }
      },
      "required": ["userId", "displayName"]
    },
    "Match": {
      "title": "Match",
      "description": "Multiplayer match state",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "guestId": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "deploying", "ready", "play", "finished"] },
        "winner": { "type": "string" },
        "turn": { "type": "number" },
        "activeTeam": { "type": "string" },
        "units": { "type": "string" },
        "gridEnv": { "type": "string" },
        "mapId": { "type": "string" },
        "suggestedMaps": { "type": "array", "items": { "type": "string" } },
        "votes": { "type": "object" },
        "voteResolved": { "type": "boolean" },
        "votedMapId": { "type": "string" },
        "aiDecisionText": { "type": "string" },
        "squadSize": { "type": "number" },
        "smogEnabled": { "type": "boolean" }
      },
      "required": ["hostId", "status"]
    },
    "CommanderStat": {
      "title": "Commander Stat",
      "description": "Commander statistics for leaderboard",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "victories": { "type": "number" }
      },
      "required": ["userId", "displayName", "victories"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "matches/{matchId}": {
      "schema": { "$ref": "#/entities/Match" },
      "description": "Stores game match state."
    },
    "stats/{userId}": {
      "schema": { "$ref": "#/entities/CommanderStat" },
      "description": "Stores user statistics."
    }
  }
}
