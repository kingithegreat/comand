rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'displayName'])
        && data.userId is string && data.userId.size() <= 128
        && data.displayName is string && data.displayName.size() <= 100
        && (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() <= 200));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && isValidId(userId)
                    && isValidUserProfile(incoming()) 
                    && incoming().userId == request.auth.uid 
                    && userId == request.auth.uid;
      allow update: if isSignedIn() 
                    && isValidUserProfile(incoming())
                    && existing().userId == request.auth.uid
                    && incoming().userId == existing().userId
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['hostId', 'status'])
        && data.hostId is string && data.hostId.size() <= 128
        && data.status is string && data.status.size() <= 20
        && (!data.keys().hasAny(['guestId']) || (data.guestId is string && data.guestId.size() <= 128))
        && (!data.keys().hasAny(['winner']) || (data.winner is string && data.winner.size() <= 128))
        && (!data.keys().hasAny(['turn']) || data.turn is number)
        && (!data.keys().hasAny(['activeTeam']) || (data.activeTeam is string && data.activeTeam.size() <= 20))
        && (!data.keys().hasAny(['units']) || (data.units is string && data.units.size() <= 50000))
        && (!data.keys().hasAny(['gridEnv']) || (data.gridEnv is string && data.gridEnv.size() <= 50000));
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn()
                    && isValidId(matchId)
                    && isValidMatch(incoming())
                    && incoming().hostId == request.auth.uid;
                    
      allow update: if isSignedIn()
                    && isValidMatch(incoming())
                    && existing().hostId == incoming().hostId
                    && (
                      existing().hostId == request.auth.uid || 
                       (existing().keys().hasAll(['guestId']) && existing().guestId == request.auth.uid) ||
                       (!existing().keys().hasAll(['guestId']) && incoming().guestId == request.auth.uid)
                    )
                    && (
                      (incoming().diff(existing()).affectedKeys().hasOnly(['guestId', 'status', 'activeTeam', 'turn', 'units', 'gridEnv', 'winner']))
                    );
                    
      allow delete: if isSignedIn() && existing().hostId == request.auth.uid;
    }
  }
}
