rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidUserProfile(data) {
      return (!data.keys().hasAny(['userId']) || (data.userId is string && data.userId.size() <= 128))
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 100))
        && (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() <= 200))
        && (!data.keys().hasAny(['characterProgress']) || data.characterProgress is map)
        && (!data.keys().hasAny(['matchHistory']) || data.matchHistory is list)
        && (!data.keys().hasAny(['friends']) || data.friends is list);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && isValidId(userId)
                    && incoming().keys().hasAll(['userId', 'displayName'])
                    && isValidUserProfile(incoming()) 
                    && incoming().userId == request.auth.uid 
                    && userId == request.auth.uid;
      allow update: if isSignedIn() 
                    && userId == request.auth.uid
                    && isValidUserProfile(incoming())
                    && (!existing().keys().hasAny(['userId']) || existing().userId == request.auth.uid)
                    && (!incoming().keys().hasAny(['userId']) || incoming().userId == request.auth.uid)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'characterProgress', 'userId', 'matchHistory', 'friends']);
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['hostId', 'status'])
        && data.hostId is string && data.hostId.size() <= 128
        && data.status is string && data.status.size() <= 20
        && (!data.keys().hasAny(['guestId']) || (data.guestId is string && data.guestId.size() <= 128))
        && (!data.keys().hasAny(['winner']) || (data.winner is string && data.winner.size() <= 128))
        && (!data.keys().hasAny(['turn']) || data.turn is number)
        && (!data.keys().hasAny(['activeTeam']) || (data.activeTeam is string && data.activeTeam.size() <= 20))
        && (!data.keys().hasAny(['units']) || (data.units is string && data.units.size() <= 50000))
        && (!data.keys().hasAny(['gridEnv']) || (data.gridEnv is string && data.gridEnv.size() <= 50000))
        && (!data.keys().hasAny(['mapId']) || (data.mapId is string && data.mapId.size() <= 128))
        && (!data.keys().hasAny(['suggestedMaps']) || data.suggestedMaps is list)
        && (!data.keys().hasAny(['votes']) || data.votes is map)
        && (!data.keys().hasAny(['voteResolved']) || data.voteResolved is bool)
        && (!data.keys().hasAny(['votedMapId']) || (data.votedMapId is string && data.votedMapId.size() <= 128))
        && (!data.keys().hasAny(['aiDecisionText']) || (data.aiDecisionText is string && data.aiDecisionText.size() <= 5000))
        && (!data.keys().hasAny(['squadSize']) || data.squadSize is number)
        && (!data.keys().hasAny(['smogEnabled']) || data.smogEnabled is bool)
        && (!data.keys().hasAny(['isPublic']) || data.isPublic is bool)
        && (!data.keys().hasAny(['isCoop']) || data.isCoop is bool)
        && (!data.keys().hasAny(['spectators']) || data.spectators is list);
    }

    function isValidCommanderStat(data) {
      return (!data.keys().hasAny(['userId']) || (data.userId is string && data.userId.size() <= 128))
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 100))
        && (!data.keys().hasAny(['victories']) || data.victories is number)
        && (!data.keys().hasAny(['campaignSectors']) || data.campaignSectors is number)
        && (!data.keys().hasAny(['totalSquadLevel']) || data.totalSquadLevel is number);
    }

    match /stats/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && userId == request.auth.uid;
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn()
                    && isValidId(matchId)
                    && isValidMatch(incoming())
                    && incoming().hostId == request.auth.uid;
                    
      allow update: if isSignedIn()
                    && isValidMatch(incoming())
                    && existing().hostId == incoming().hostId
                    && (
                      existing().hostId == request.auth.uid || 
                       (existing().keys().hasAll(['guestId']) && existing().guestId == request.auth.uid) ||
                       (!existing().keys().hasAll(['guestId']) && incoming().guestId == request.auth.uid)
                    )
                    && (
                      (incoming().diff(existing()).affectedKeys().hasOnly([
                        'guestId', 'status', 'activeTeam', 'turn', 'units', 'gridEnv', 'winner',
                        'mapId', 'suggestedMaps', 'votes', 'voteResolved', 'votedMapId', 'aiDecisionText',
                        'squadSize', 'smogEnabled', 'isCoop', 'spectators'
                      ]))
                    );
                    
      allow delete: if isSignedIn() && existing().hostId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && incoming().keys().hasAll(['text', 'senderId', 'senderName', 'timestamp'])
                      && incoming().senderId == request.auth.uid
                      && incoming().text is string && incoming().text.size() <= 400;
        allow update, delete: if false;
      }
    }
  }
}
